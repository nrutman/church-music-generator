{
  "name": "church-music-generator",
  "version": "1.0.0",
  "description": "Generate Providence Church-format chord and lyric sheet .docx files",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "generate": "pnpm build && bash src/build.sh",
    "check-deps": "bash src/check-deps.sh",
    "preview": "bash src/preview.sh",
    "clean-previews": "rm -rf generated/preview && echo 'Cleaned up preview files.'"
  },
  "dependencies": {
    "docx": "^9.6.0",
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/opentype.js": "^1.3.9",
    "eslint": "^10.0.2",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
