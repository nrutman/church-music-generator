{
  "name": "church-music-generator",
  "version": "1.0.0",
  "description": "Generate Providence Church-format chord and lyric sheet .docx files",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "generate": "pnpm build && bash src/build.sh"
  },
  "dependencies": {
    "docx": "^9.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
